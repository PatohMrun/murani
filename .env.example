# Database (Supabase Postgres — use pooler URL for DATABASE_URL, direct URL for migrations)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Supabase (public — safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Supabase service role — NEVER expose to browser
SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# Admin — email of the only Supabase user allowed to access /admin
ADMIN_EMAIL="you@example.com"

# HMAC secret for hashing IPs (rate limiting, comment spam protection)
# Generate with: openssl rand -hex 32
HMAC_SECRET="your-secret-here"

# EmailJS (contact form — all values are NEXT_PUBLIC, visible in browser)
NEXT_PUBLIC_EMAILJS_SERVICE_ID="service_xxxxxxx"
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID="template_xxxxxxx"
NEXT_PUBLIC_EMAILJS_USER_ID="user_xxxxxxx"

# APK download allowlist (comma-separated hostnames allowed as download sources)
ALLOWED_DOWNLOAD_HOSTS="example.com,cdn.example.com"
